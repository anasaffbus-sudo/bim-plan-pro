# BIM Plan Pro — متغيّرات البيئة
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# لا ترفع ملف .env إلى git أبداً

# مفتاح سرّي لجلسات Flask (ولّد قيمة عشوائية طويلة)
SECRET_KEY=change-me-to-a-long-random-string

# بيئة التشغيل: development | production
FLASK_ENV=production

# المنفذ (يُعيّنه Render تلقائياً - لا تغيّره)
# PORT=5000

# Google OAuth 2.0 (مطلوب لتسجيل الدخول بحساب Google)
# احصل عليها من: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://bim-plan-pro.onrender.com/api/auth/google/callback
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
