# BIM Plan Pro — متغيّرات البيئة
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# لا ترفع ملف .env إلى git أبداً

# مفتاح سرّي لجلسات Flask (ولّد قيمة عشوائية طويلة)
SECRET_KEY=change-me-to-a-long-random-string

# بيئة التشغيل: development | production
FLASK_ENV=production

# المنفذ (يُعيّنه Render تلقائياً - لا تغيّره)
# PORT=5000
